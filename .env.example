# ============================================================
# Agent Settlement Protocol — variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# NE JAMAIS committer le fichier .env
# ============================================================

# Clé privée du wallet deployer (Base Sepolia uniquement)
# Ce wallet joue aussi le rôle d'évaluateur dans la version MVP
# Ne jamais utiliser un wallet avec des fonds réels
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# RPC URL pour Base Sepolia
# Gratuit : https://sepolia.base.org
# Recommandé : Alchemy ou Infura pour éviter les rate limits
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Clé API Etherscan pour la vérification des contrats (optionnel)
# Obtenir sur https://etherscan.io/myapikey (supporte Base Sepolia via V2)
ETHERSCAN_API_KEY=

# Clé de chiffrement AES-256 pour les wallets managés de l'API
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_ENCRYPTION_KEY=YOUR_32_BYTES_HEX_KEY

# Port de l'API (optionnel, défaut : 3000)
PORT=3000
